          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "breakeven"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    4
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "gray"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT\n  ts AS time,\n  strategy,\n  AVG(pnl) OVER (\n    PARTITION BY strategy ORDER BY ts\n    ROWS BETWEEN 19 PRECEDING AND CURRENT ROW\n  ) AS rolling_avg_pnl\nFROM polymarket_trades\nWHERE won IS NOT NULL\n  AND ('$paper' = 'all' OR paper::text = '$paper')\n  AND strategy ~ '${strategy:pipe}'\n  AND $__timeFilter(ts)\nORDER BY ts",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT ts AS time, 0 AS \"breakeven\" FROM polymarket_trades WHERE $__timeFilter(ts) ORDER BY ts LIMIT 2",
          "format": "time_series",
          "refId": "B"
        }
      ]
    }
  ]
