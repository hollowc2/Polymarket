              { "id": "custom.width", "value": 60 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "text", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "text", "value": 30 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Win%" },
