              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 80 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 0.001 }
