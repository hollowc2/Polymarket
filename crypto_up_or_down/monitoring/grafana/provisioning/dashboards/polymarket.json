              { "id": "custom.width", "value": 50 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Date/Time" },
            "properties": [
              { "id": "custom.width", "value": 110 }
            ]
