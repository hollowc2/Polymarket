              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 75 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "BE%" },
