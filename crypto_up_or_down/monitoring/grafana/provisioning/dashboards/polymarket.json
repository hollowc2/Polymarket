              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "text", "value": 0 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "MaxCL" },
            "properties": [
              { "id": "custom.width", "value": 70 }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://metrics-server:9099/api/leaderboard",
          "format": "table",
          "columns": [
            { "selector": "bot",               "text": "Bot",         "type": "string" },
