            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Bot" },
            "properties": [
              { "id": "custom.width", "value": 200 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trades",
                    "url": "/d/polymarket-leaderboard?var-bot=${__data.fields.Bot}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "n" },
